{
  "name": "@universal-robots/contribution-api",
  "version": "21.3.131",
  "description": "Library for Universal Robot's URCap API components and assets",
  "license": "See LICENSE.pdf",
  "author": "Universal Robots",
  "keywords": [
    "@universal-robots/contribution-api"
  ],
  "main": "src/index.ts",
  "peerDependencies": {
    "@universal-robots/ros2-foxglove-interfaces": "^4.1.3",
    "@universal-robots/ros2-interfaces": "*",
    "@universal-robots/ui-models": "*",
    "@universal-robots/utilities-units": "*",
    "guid-typescript": "~1.0.9",
    "rxjs": "~7.8.1",
    "threads": "~1.7.0",
    "three": "~0.177.0",
    "ts-md5": "^2.0.1"
  },
  "module": "fesm2022/universal-robots-contribution-api.mjs",
  "typings": "types/universal-robots-contribution-api.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./types/universal-robots-contribution-api.d.ts",
      "default": "./fesm2022/universal-robots-contribution-api.mjs"
    },
    "./angular": {
      "types": "./types/universal-robots-contribution-api-angular.d.ts",
      "default": "./fesm2022/universal-robots-contribution-api-angular.mjs"
    },
    "./testing": {
      "types": "./types/universal-robots-contribution-api-testing.d.ts",
      "default": "./fesm2022/universal-robots-contribution-api-testing.mjs"
    }
  },
  "sideEffects": false,
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "scripts": {
    "prepublishOnly": "node --eval \"console.error('ERROR: Trying to publish a package that has been compiled in full compilation mode. This is not allowed.\\nPlease delete and rebuild the package with partial compilation mode, before attempting to publish.\\n')\" && exit 1"
  }
}
